# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_tools

# Redis (BullMQ + cache + rate limiting)
REDIS_URL=redis://localhost:6379

# Brave Search API
BRAVE_API_KEY=BSA...

# Bright Data Proxy (for browser tool)
BRIGHT_DATA_PROXY=http://user:pass@brd.superproxy.io:22225

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Crypto (USDC on Base)
CRYPTO_HD_MNEMONIC=
ALCHEMY_WEBHOOK_SECRET=

# OpenAI (optional, for smart extraction)
OPENAI_API_KEY=sk-...

# Application
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Credits per operation
CREDIT_SEARCH=1
CREDIT_SCRAPE=2
CREDIT_BROWSE=5
CREDIT_DOCUMENT=3
CREDIT_EXECUTE_PER_10S=1
